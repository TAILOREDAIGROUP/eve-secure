{
  "name": "eve-secure",
  "version": "0.1.0",
  "description": "EVE Secure - AI Security Evaluation Platform",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "vitest run --reporter=verbose",
    "test:integration": "vitest run --reporter=verbose --config vitest.config.integration.ts",
    "test:e2e": "playwright test",
    "test:eval": "node scripts/eval/run-evaluations.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "db:migrate": "node scripts/db/migrate.js",
    "db:seed": "node scripts/db/seed.js",
    "db:reset": "node scripts/db/reset.js",
    "eval:accuracy": "node scripts/eval/accuracy.js",
    "eval:injection": "node scripts/eval/injection-detection.js",
    "eval:isolation": "node scripts/eval/isolation.js",
    "eval:harm": "node scripts/eval/harm-detection.js"
  },
  "dependencies": {
    "next": "^14.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@clerk/nextjs": "^5.0.0",
    "@supabase/supabase-js": "^2.39.0",
    "@openai/sdk": "^4.28.0",
    "zod": "^3.22.4",
    "zustand": "^4.4.7",
    "@tanstack/react-query": "^5.28.0",
    "@aws-sdk/client-s3": "^3.515.0",
    "@aws-sdk/client-kms": "^3.515.0",
    "@aws-sdk/client-secrets-manager": "^3.515.0",
    "resend": "^3.0.0",
    "twilio": "^4.10.0",
    "ioredis": "^5.3.2",
    "bcryptjs": "^2.4.3",
    "uuid": "^9.0.1",
    "date-fns": "^3.3.1",
    "lucide-react": "^0.363.0",
    "tailwindcss": "^3.4.1",
    "@react-pdf/renderer": "^3.16.0",
    "sharp": "^0.33.0",
    "dotenv": "^16.3.1",
    "pino": "^8.17.2",
    "pino-pretty": "^10.2.3",
    "axios": "^1.6.5",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@types/bcryptjs": "^2.4.2",
    "@types/uuid": "^9.0.7",
    "vitest": "^1.1.0",
    "@vitest/ui": "^1.1.0",
    "@testing-library/react": "^14.1.2",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/user-event": "^14.5.1",
    "playwright": "^1.41.2",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-@typescript-eslint": "^6.16.0",
    "prettier": "^3.1.1",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "@types/jest": "^29.5.11",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=18.17.0",
    "npm": ">=9.0.0"
  }
}
